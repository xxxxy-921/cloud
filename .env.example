# Server
SERVER_PORT=8080

# Database: "sqlite" (default) or "postgres"
DB_DRIVER=sqlite
DB_DSN=metis.db?_pragma=foreign_keys(1)&_pragma=journal_mode(WAL)

# PostgreSQL example:
# DB_DRIVER=postgres
# DB_DSN=host=localhost port=5432 user=metis password=secret dbname=metis sslmode=disable

# OpenTelemetry (all optional, disabled by default)
# OTEL_ENABLED=true
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:10428/insert/opentelemetry
# OTEL_SERVICE_NAME=metis
# OTEL_SAMPLE_RATE=1.0
